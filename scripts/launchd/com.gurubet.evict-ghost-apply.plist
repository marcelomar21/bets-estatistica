<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gurubet.evict-ghost-apply</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/wehandle/Projetos/pessoal/bets-estatistica/scripts/run-evict-ghost.sh</string>
        <string>--apply</string>
        <string>--notify-admin</string>
    </array>

    <!-- 2026-05-01 18:00 UTC = 15:00 BRT (execute kicks). -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Month</key>
        <integer>5</integer>
        <key>Day</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/evict-ghost-apply.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/evict-ghost-apply.err</string>

    <!-- RunAtLoad=false: we only want this on the scheduled date. -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
